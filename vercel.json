{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    },
    {
      "src": "server.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["db.json"]
      }
    }
  ],
  "routes": [
    { "src": "/admin/?.*", "dest": "/server.mjs" },
    { "src": "/auth/?.*", "dest": "/server.mjs" },
    { "src": "/api/?.*", "dest": "/server.mjs" },
    { "src": "/uploads/?.*", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ]
}
