{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/admin/?.*", "dest": "/server.mjs" },
    { "src": "/auth/?.*", "dest": "/server.mjs" },
    { "src": "/api/?.*", "dest": "/server.mjs" },
    { "src": "/uploads/?.*", "dest": "/server.mjs" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ]
}
